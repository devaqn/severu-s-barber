============================================================
Severus Barber - variaveis de ambiente (--dart-define)
Copie este arquivo, renomeie para .env e preencha com seus valores reais.
NUNCA commite o arquivo .env no git.
============================================================

# -- Firebase: compartilhado entre plataformas --
FIREBASE_PROJECT_ID=seu-projeto-firebase
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com

# -- Firebase: Web --
FIREBASE_WEB_API_KEY=AIzaSy...
FIREBASE_WEB_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# -- Firebase: Android --
FIREBASE_ANDROID_API_KEY=AIzaSy...
FIREBASE_ANDROID_APP_ID=1:000000000000:android:xxxxxxxxxxxxxxxx

# -- Firebase: iOS --
FIREBASE_IOS_API_KEY=AIzaSy...
FIREBASE_IOS_APP_ID=1:000000000000:ios:xxxxxxxxxxxxxxxx
FIREBASE_IOS_BUNDLE_ID=com.severusbarber.app

# -- Firebase: macOS --
FIREBASE_MACOS_API_KEY=AIzaSy...
FIREBASE_MACOS_APP_ID=1:000000000000:macos:xxxxxxxxxxxxxxxx
FIREBASE_MACOS_BUNDLE_ID=com.severusbarber.app

# -- Firebase: Windows --
FIREBASE_WINDOWS_API_KEY=AIzaSy...
FIREBASE_WINDOWS_APP_ID=1:000000000000:windows:xxxxxxxxxxxxxxxx

# -- Firebase: Linux --
FIREBASE_LINUX_API_KEY=AIzaSy...
FIREBASE_LINUX_APP_ID=1:000000000000:linux:xxxxxxxxxxxxxxxx

# -- Conta de teste Firebase (opcional, para QA) --
FIREBASE_TEST_ADMIN_EMAIL=admin@seuteste.com
FIREBASE_TEST_ADMIN_PASSWORD=SenhaForte@123
FIREBASE_TEST_ADMIN_NAME=Administrador Teste

# -- Modo offline / desenvolvimento sem Firebase --
# Use apenas localmente. NUNCA em producao.
ENABLE_OFFLINE_LOGIN=false
OFFLINE_ADMIN_EMAIL=admin@offline.local
OFFLINE_ADMIN_PASSWORD=SenhaForte@123

# -- Atalho de conta de teste na tela de login (debug only) --
# false em producao, true apenas para QA
ENABLE_FIREBASE_TEST_SHORTCUT=false
