rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function userPath(shopId) {
      return /databases/$(database)/documents/barbearias/$(shopId)/usuarios/$(request.auth.uid);
    }

    function isInShop(shopId) {
      return isAuth()
        && exists(userPath(shopId))
        && get(userPath(shopId)).data.revoked != true;
    }

    function getUser(shopId) {
      return get(userPath(shopId)).data;
    }

    function isAdmin(shopId) {
      return isInShop(shopId) && getUser(shopId).role == 'admin';
    }

    function isBarbeiro(shopId) {
      return isInShop(shopId) && getUser(shopId).role == 'barbeiro';
    }

    function clientProtectedFieldsAbsent() {
      return !request.resource.data.keys().hasAny([
        'total_gasto',
        'pontos_fidelidade',
        'total_atendimentos'
      ]);
    }

    function clientProtectedFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'total_gasto',
        'pontos_fidelidade',
        'total_atendimentos'
      ]);
    }

    function productPriceFieldsAbsent() {
      return !request.resource.data.keys().hasAny([
        'preco_venda',
        'preco_custo',
        'estoque_minimo'
      ]);
    }

    function productPriceFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'preco_venda',
        'preco_custo',
        'estoque_minimo'
      ]);
    }

    function isBootstrapAdmin(shopId, uid) {
      return isAuth()
        && uid == request.auth.uid
        && shopId == 'shop_' + request.auth.uid
        && request.resource.data.role == 'admin'
        && request.resource.data.ativo == true
        && request.resource.data.barbearia_id == shopId;
    }

    match /barbearias/{shopId} {
      allow read: if isInShop(shopId);
      allow create: if isAuth()
        && shopId == 'shop_' + request.auth.uid
        && request.resource.data.created_by == request.auth.uid;
      allow update: if isInShop(shopId) && isAdmin(shopId);
    }

    match /barbearias/{shopId}/usuarios/{uid} {
      allow read: if isInShop(shopId) && (isAdmin(shopId) || request.auth.uid == uid);
      allow write: if (isInShop(shopId) && isAdmin(shopId)) || isBootstrapAdmin(shopId, uid);
    }

    match /barbearias/{shopId}/clientes/{id} {
      allow read: if isInShop(shopId);
      allow create: if isInShop(shopId)
        && (isAdmin(shopId) || (isBarbeiro(shopId) && clientProtectedFieldsAbsent()));
      allow update: if isInShop(shopId)
        && (isAdmin(shopId) || (isBarbeiro(shopId) && clientProtectedFieldsUnchanged()));
      allow delete: if isInShop(shopId) && isAdmin(shopId);
    }

    match /barbearias/{shopId}/servicos/{id} {
      allow read: if isInShop(shopId);
      allow write: if isInShop(shopId) && isAdmin(shopId);
    }

    match /barbearias/{shopId}/produtos/{id} {
      allow read: if isInShop(shopId);
      allow create: if isInShop(shopId)
        && (isAdmin(shopId) || (isBarbeiro(shopId) && productPriceFieldsAbsent()));
      allow update: if isInShop(shopId)
        && (isAdmin(shopId) || (isBarbeiro(shopId) && productPriceFieldsUnchanged()));
      allow delete: if isInShop(shopId) && isAdmin(shopId);
    }

    match /barbearias/{shopId}/comandas/{id} {
      allow read: if isInShop(shopId);
      allow create: if isInShop(shopId) && (isAdmin(shopId) || isBarbeiro(shopId));
      allow update: if isInShop(shopId)
        && (isAdmin(shopId)
          || resource.data.barbeiro_uid == request.auth.uid
          || request.resource.data.barbeiro_uid == request.auth.uid);
      allow delete: if isInShop(shopId) && isAdmin(shopId);

      match /itens/{itemId} {
        allow read: if isInShop(shopId);
        allow write: if isInShop(shopId)
          && (isAdmin(shopId)
            || get(/databases/$(database)/documents/barbearias/$(shopId)/comandas/$(id)).data.barbeiro_uid == request.auth.uid);
      }
    }

    match /barbearias/{shopId}/despesas/{id} {
      allow read, write: if isInShop(shopId) && isAdmin(shopId);
    }

    match /barbearias/{shopId}/caixas/{id} {
      allow read, write: if isInShop(shopId) && isAdmin(shopId);
    }

    match /barbearias/{shopId}/agendamentos/{id} {
      allow read: if isInShop(shopId);
      allow create: if isInShop(shopId) && (isAdmin(shopId) || isBarbeiro(shopId));
      allow update: if isInShop(shopId)
        && (isAdmin(shopId)
          || resource.data.barbeiro_id == request.auth.uid
          || request.resource.data.barbeiro_id == request.auth.uid);
      allow delete: if isInShop(shopId) && (isAdmin(shopId) || resource.data.barbeiro_id == request.auth.uid);
    }

    match /barbearias/{shopId}/estoque/{id} {
      allow read, write: if isInShop(shopId) && (isAdmin(shopId) || isBarbeiro(shopId));
    }

    match /barbearias/{shopId}/{collection}/{id} {
      allow read, write: if isInShop(shopId) && isAdmin(shopId);
    }
  }
}

