# ==============================
# Severus Barber - Git Ignore
# Produção: dependências, cache, binários e segredos locais
# ==============================

# General
*.class
*.log
*.tmp
*.swp
.DS_Store

# IDE
.idea/
*.iml
*.ipr
*.iws

# VS Code local workspace settings (opcional)
# .vscode/

# Flutter / Dart cache
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub/
.pub-cache/
.packages

# Build outputs (todas plataformas)
build/
**/build/
coverage/

# Flutter generated (mobile/desktop)
ios/Flutter/ephemeral/
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh
ios/Runner/GeneratedPluginRegistrant.h
ios/Runner/GeneratedPluginRegistrant.m
macos/Flutter/ephemeral/
linux/flutter/ephemeral/
windows/flutter/ephemeral/

# Android generated/dependencies
android/.gradle/
android/local.properties
android/app/debug/
android/app/profile/
android/app/release/

# Binary artifacts
*.apk
*.aab
*.exe

# Environment and secrets
.env
*.env
!.env.example
key.properties
android/key.properties
android/app/google-services.json
*.keystore
*.jks
